" basic configuration settings
set laststatus=2
set ttymouse=sgr
set mouse=a
set signcolumn=no
set tabstop=4
set shiftwidth=4

set autoindent
set nowrap
set ignorecase

syntax on

" highlighting
highlight StatusLine 	ctermfg=0
highlight NonText 	    ctermfg=8
highlight SignColumn 	ctermbg=0

" keybindings
