--enable-dbgutil
--with-jdk-home=/usr/lib/jvm/openjdk17
--without-junit
--without-doxygen
--enable-ccache
--enable-kf6
--enable-compiler-plugins
--with-help=html
--with-system-libxml=no
--enable-odk
--with-extra-cc-flags=-fdiagnostics-color=always
--with-extra-cxx-flags=-fdiagnostics-color=always
CC=clang
CXX=clang++
