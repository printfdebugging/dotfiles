#!/bin/sh

# Show wifi ًں“¶ and percent strength or ًں“، if none.
# Show ًںŒگ if connected to ethernet or â‌ژ if none.
# Show ًں”’ if a vpn connection is active

# Wifi َ°¤ں َ°¤¢ َ°¤¥ َ°¤¨
if [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'up' ] ; then

	 strength="$(awk '/^\s*w/ { print int($3 * 100 / 70)}' /proc/net/wireless)"
     # strengthrem=$(($strength/10 )) # find the int division with 10
     # strength=$(( $strengthrem*10 )) # multiply with 10

     # install wireless tools
     hostname=$(iwgetid -r)
     # short="${hostname:0:5}.."
     short=$hostname
     wifiicon="ًں“، $short"
# ($strength)
     # case $strength in 
     #     100|90|80)     wifiicon="َ°¤¨ ($strength)";;
     #     70|60|50)      wifiicon="َ°¤¢ ($strength)";;
     #     40|30)         wifiicon="َ°¤¢ ($strength)";;
     #     20|10)         wifiicon="َ°¤ں ($strength)";;
     # esac

	# wifiicon="$(awk '/^\s*w/ { print "ï‡«  "}' /proc/net/wireless)"
	# wifiicon="$(awk '/^\s*w/ { print "ï‡« ", int($3 * 100 / 70) "% " }' /proc/net/wireless)"
elif [ "$(cat /sys/class/net/w*/operstate 2>/dev/null)" = 'down' ] ; then
	[ "$(cat /sys/class/net/w*/flags 2>/dev/null)" = '0x1003' ] && wifiicon="ًں”چ" || wifiicon="â‌Œ "
fi

# Ethernet
[ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'up' ] && ethericon=" ًں”— " || ethericon=""


# USB tetering
usb=""
output=$(cat /sys/class/net/e*/operstate 2>/dev/null)
for i in $output
do
    if [ $i = 'unknown' ]
    then
        usb=" ًں“± "
    fi
done
# [ "$(cat /sys/class/net/e*/operstate 2>/dev/null)" = 'unknown' ] && usb="ًںŒگ " || usb="â‌ژ "

# TUN
[ -n "$(cat /sys/class/net/tun*/operstate 2>/dev/null)" ] && tunicon="ًں”’ "

# printf "[%s%s%s]\n" "$wifiicon" "$ethericon" "$usb"
printf " %s%s%s  \n" "$wifiicon" "$ethericon" "$usb"
