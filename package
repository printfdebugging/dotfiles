function pam() {
    system_login_file="/etc/pam.d/system-local-login"
    if [ -f "$system_login_file" ]; then
        lines=(
            'auth     optional  pam_gnupg.so store-only'
            'session  optional  pam_gnupg.so'
        )
        for line in "${lines[@]}"; do
            if [ "$(grep -c "$line" "$system_login_file")" -eq 0 ]; then
                echo "$line" | sudo tee -a "$system_login_file" >/dev/null 2>&1
            fi
        done
    else
        echo "$system_login_file file not found" && exit 1
    fi

    i3lock_file="/etc/pam.d/i3lock"
    if [ -f "$i3lock_file" ]; then
        lines=(
            'auth     optional  pam_gnupg.so'
        )
        for line in "${lines[@]}"; do
            if [ "$(grep -c "$line" "$i3lock_file")" -eq 0 ]; then
                echo "$line" | sudo tee -a "$i3lock_file" >/dev/null 2>&1
            fi
        done
    else
        echo "$i3lock_file file not found" && exit 1
    fi
}

