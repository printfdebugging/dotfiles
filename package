function aur() {
    if ! which yay >/dev/null 2>&1; then
        mkdir -p "$HOME/.local/src" && cd "$HOME/.local/src" || exit 1
        git clone https://aur.archlinux.org/yay-bin.git >/dev/null 2>&1
        cd yay-bin && makepkg -si --noconfirm >/dev/null 2>&1
    fi

    yay -Sy --noconfirm \
        'brave-bin' \
        'pam-gnupg' \
        'par' \
        'gtypist'
}

function services() {
    sudo systemctl enable --now \
        'bluetooth.service' \
        'nginx.service' \
        'blueman-mechanism.service' \
        'libvirtd.service' \
        'docker.service' \
        'tlp.service'
}

function groups() {
    groups=(
        'libvirt'
        'kvm'
        'docker'
    )
    # append user to groups
    for group in "${groups[@]}"; do
        sudo usermod -aG "$group" "$(whoami)"
    done
}

# call after setup_drives
function repos() {
    git_repositories=(
        'https://gerrit.libreoffice.org/core'
        'https://github.com/CollaboraOnline/online'
        'https://github.com/printfdebugging/skia'
        'https://github.com/printfdebugging/learn-opengl'

        'https://gitlab.com/printfdebugging/logs'
        'https://gitlab.com/printfdebugging/website'
    )
    # clone git repositories
    for repository in "${git_repositories[@]}"; do
        projects_dir="/media/projects"
        repo_name="$(echo "$repository" | sed 's#.*/##')"
        if ! [ -d "$projects_dir/$repo_name" ]; then
            git clone "$repository" "$projects_dir/$repo_name"
        fi
    done
}

function suckless() {
    suckless_projects=(
        'dwm'
        'st'
        'dmenu'
    )
    for suckless in "${suckless_projects[@]}"; do
        suckless_dir="$HOME/.local/src/$suckless"
        if ! [ -d "$suckless_dir" ]; then
            mkdir -p "$suckless_dir"
            git clone "https://gitlab.com/printfdebugging/$suckless.git" "$suckless_dir"
        fi

        echo -e "$CYN==>$CLR compiling $GRN$suckless$CLR"
        sudo make -C "$suckless_dir" install >/dev/null 2>&1
    done
}

