function qemuConf() {
    if ! sudo virsh net-info --network default | grep "Active:.*yes" >/dev/null 2>&1; then
        echo -e "$GRN==>$CLR enabling virsh default"
        sudo virsh net-start default >/dev/null 2>&1
        sudo virsh net-autostart default >/dev/null 2>&1
    fi

    # uncomment lines in libvirtd.conf
    lines=(
        'unix_sock_group = "libvirt"'
        'unix_sock_rw_perms = "0770"'
    )
    for line in "${lines[@]}"; do
        sudo sed -i "/$line/s/^#//" /etc/libvirt/libvirtd.conf
    done
}

