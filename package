function creds() {
    mkdir -p "$HOME/.ssh"
    mkdir -p "$HOME/.gnupg"

    cp ./.gitconfig \
        ./.gpgkey.asc \
        ./.pgpkey.asc \
        ./.pam-gnupg \
        "$HOME/"

    cp ./id_ed25519 \
        ./id_ed25519.pub \
        ./printfdebugging \
        ./printfdebugging.pub \
        ./cool \
        ./cool.pub \
        ./config \
        "$HOME/.ssh"

    cp ./gpg-agent.conf \
        ./gpg.conf \
        "$HOME/.gnupg"

    echo -e "$GRN==>$CLR decrypting credentials"
    while true; do
        ansible-vault decrypt \
            "$HOME/.gitconfig" \
            "$HOME/.gpgkey.asc" \
            "$HOME/.pgpkey.asc" \
            "$HOME/.pam-gnupg" \
            "$HOME/.gnupg/gpg-agent.conf" \
            "$HOME/.gnupg/gpg.conf" \
            "$HOME/.ssh/id_ed25519" \
            "$HOME/.ssh/id_ed25519.pub" \
            "$HOME/.ssh/printfdebugging" \
            "$HOME/.ssh/printfdebugging.pub" \
            "$HOME/.ssh/cool" \
            "$HOME/.ssh/cool.pub" \
            "$HOME/.ssh/config" >/dev/null 2>&1 && break
    done

    gpg --import "$HOME/.pgpkey.asc" >/dev/null 2>&1

    chown -R "$(whoami)" "$HOME/.gnupg"
    find "$HOME/.gnupg" -type f -exec chmod 600 {} \;
    find "$HOME/.gnupg" -type d -exec chmod 700 {} \;

    # get ssh keys for github and gitlab
    servers=(
        'github.com'
        'gitlab.com'
    )
    for server in "${servers[@]}"; do
        ssh-keyscan -t rsa "$server" >>"$HOME/.ssh/known_hosts"
    done
}

