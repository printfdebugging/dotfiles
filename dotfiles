            if ! which yay >/dev/null 2>&1; then
                mkdir -p "$HOME/.local/src" && cd "$HOME/.local/src" || exit 1
                git clone https://aur.archlinux.org/yay-bin.git && cd yay-bin && makepkg -si --noconfirm
            fi

            yay -Sy --noconfirm \
                'brave-bin' \
                'pam-gnupg' \
                'par' \
                'gtypist' \
                'light'
        }
        ;;

    "services")
        {
            sudo systemctl enable --now \
                'bluetooth.service' \
                'nginx.service' \
                'blueman-mechanism.service' \
                'libvirtd.service' \
                'docker.service' \
                'tlp.service'
        }
        ;;

    "groups")
        {
            groups=(
                'libvirt'
                'kvm'
                'docker'
            )
            # append user to groups
            for group in "${groups[@]}"; do
                sudo usermod -aG "$group" "$(whoami)"
            done
        }
        ;;

    "drives")
        {
            declare -A external=(
                [UUID]=6a90a7e3-3732-4b58-8a3a-fbc098a86b7e
                [PATH]=/media/external/
                [TYPE]=ext4
                [OPTIONS]='defaults 0 0'
            )

            declare -A personal=(
                [UUID]=18bd0da1-8e29-4d5a-a3bf-4cf8a012699d
                [PATH]=/media/personal/
                [TYPE]=ext4
                [OPTIONS]='defaults 0 0'
            )

            declare -A projects=(
                [UUID]=379872b5-a96a-4d1f-ad83-231cc27b7c6a
                [PATH]=/media/projects/
                [TYPE]=ext4
                [OPTIONS]='defaults 0 0'
            )

            declare -A archive=(
                [UUID]=4313c35d-7d9e-4e77-871e-7c70fdd1e01d
                [PATH]=/media/archive/
                [TYPE]=ext4
                [OPTIONS]='defaults 0 0'
            )

            drives=(
                external
                projects
                personal
                archive
            )

            modified=false
            for drive_name in "${drives[@]}"; do
                declare -n drive="$drive_name"
                [ -d "${drive[PATH]}" ] || sudo mkdir -p "${drive[PATH]}" && sudo chown "$(whoami):$(whoami)" "${drive[PATH]}"
                [ "$(lsblk -f | grep -c "${drive[UUID]}")" -eq 0 ] && continue
                [ "$(grep -e "${drive[UUID]}" /etc/fstab)" == "" ] && echo "UUID=${drive[UUID]} ${drive[PATH]} ${drive[TYPE]} ${drive[OPTIONS]}" | sudo tee -a /etc/fstab && modified=true
            done
            [ "$modified" ] && sudo mount -a
        }
        ;;

    "pacman")
        {
            local_folder=/media/external/archlinux
            remote_mirror=rsync://de.arch.mirror.kescher.at/mirror/arch/
            rsync -rlv \
                --exclude '/archive' \
                --exclude '/community' \
                --exclude '/community-staging' \
                --exclude '/community-testing' \
                --exclude '/core-debug' \
                --exclude '/core-staging' \
                --exclude '/core-staging-debug' \
                --exclude '/core-testing' \
                --exclude '/core-testing-debug' \
                --exclude '/extra-debug' \
                --exclude '/extra-staging' \
                --exclude '/extra-staging-debug' \
                --exclude '/extra-testing' \
                --exclude '/extra-testing-debug' \
                --exclude '/gnome-unstable' \
                --exclude '/gnome-unstable-debug' \
                --exclude '/images' \
                --exclude '/iso' \
                --exclude '/kde-unstable' \
                --exclude '/kde-unstable-debug' \
                --exclude '/latest' \
                --exclude '/multilib-debug' \
                --exclude '/multilib-staging' \
                --exclude '/multilib-staging-debug' \
                --exclude '/multilib-testing' \
                --exclude '/multilib-testing-debug' \
                --exclude '/other' \
                --exclude '/pool/packages-debug' \
                --exclude '/staging' \
                --exclude '/testing' \
                --exclude '/wsl' \
                "${remote_mirror}" \
                "${local_folder}"
        }
        ;;

    "mirrorlist")
        {
            if curl -s http://127.0.0.1:9000/ | grep -qE 'core/|extra/|multilib/|lastsync|lastupdate'; then
                sfcp mirrorlist /etc/pacman.d
                sfcp pacman.conf /etc
                sudo systemctl mask reflector.service
            fi
        }
        ;;

    "browser")
        {
            chromium_extensions=(
                'bhlhnicpbhignbdhedgjhgdocnmhomnp'
                'cjpalhdlnbpafiamejdnhcphjbkeiagm'
                'dbepggeogbaibhgnhhndojpepiihcmeb'
                'dpjamkmjmigaoobjbekmfgabipmfilij'
                'eimadpbcbfnmbkopoojfekhnkhdbieeh'
                'kchgllkpfcggmdaoopkhlkbcokngahlg'
            )
            # create the extension files
            sudo mkdir -p "/usr/share/chromium/extensions/"
            for extension in "${chromium_extensions[@]}"; do
                if ! [ -f "/usr/share/chromium/extensions/$extension.json" ]; then
                    echo '{ "external_update_url": "https://clients2.google.com/service/update2/crx" }' | sudo tee "/usr/share/chromium/extensions/$extension.json" >/dev/null 2>&1
                fi
            done
        }
        ;;

    "suckless")
        {
            # clean previous clone
            source_dir="$HOME/.local/src"
            sudo rm -rf "$source_dir" && mkdir -p "$source_dir"

            # clone and compile from source
            for suckless in 'dwm' 'st' 'dmenu'; do
                git clone "https://gitlab.com/printfdebugging/$suckless.git" "$source_dir/$suckless"
                sudo make -C "$source_dir/$suckless" install >/dev/null 2>&1
            done
        }
        ;;

    "passwords")
        {
            [ -d "$HOME/.password-store" ] || git clone git@gitlab.com:printfdebugging/password-store "$HOME/.password-store" >/dev/null 2>&1
            [ -f "$HOME/.password-store/.git/hooks/post-commit" ] || printf "#\!/bin/bash\n\ngit push" | tee "$HOME/.password-store/.git/hooks/post-commit" >/dev/null 2>&1
        }
        ;;

    "git")
        {
            # create project directory
            directory=/media/projects
            [ -d "$directory" ] || { sudo mkdir -p "$directory" && sudo chown "$(whoami):$(whoami)" "$directory"; }

            git_repositories=(
                'https://gerrit.libreoffice.org/core'
                'https://github.com/CollaboraOnline/online'
                'https://github.com/printfdebugging/skia'
                'https://github.com/printfdebugging/learn-opengl'
                'https://gitlab.com/printfdebugging/logs'
                'https://gitlab.com/printfdebugging/website'
                'https://gitlab.com/printfdebugging/bin'
            )
            # clone git repositories
            for repository in "${git_repositories[@]}"; do
                name=$(echo "$repository" | awk -F'/' '{print $NF}')
                [ -d "$directory/$name" ] || git clone "$repository" "$directory/$name"
            done
        }
        ;;

    "shell") chsh -s /usr/bin/zsh && sudo chsh -s /usr/bin/zsh ;;

    "pam-gnupg")
        {
            sysloginfile="/etc/pam.d/system-local-login"
            sysloginline_a='auth     optional  pam_gnupg.so store-only'
            sysloginline_b='session  optional  pam_gnupg.so'
            [ -f "$sysloginfile" ] && [ "$(grep -c "$sysloginline_a" "$sysloginfile")" -eq 0 ] && echo "$sysloginline_a" | sudo tee -a "$sysloginfile"
            [ -f "$sysloginfile" ] && [ "$(grep -c "$sysloginline_b" "$sysloginfile")" -eq 0 ] && echo "$sysloginline_b" | sudo tee -a "$sysloginfile"
            i3lokfile="/etc/pam.d/i3lock"
            i3line='auth     optional  pam_gnupg.so'
            [ -f "$i3lokfile" ] && [ "$(grep -c "$i3line" "$i3lokfile")" -eq 0 ] && echo "$i3line" | sudo tee -a "$i3lokfile"
        }
        ;;

    "qemu")
        {
            [ "$(sudo virsh net-info --network default | grep -c "Active:.*yes")" -ne 0 ] || sudo virsh net-start default
            [ "$(sudo virsh net-info --network default | grep -c "Autostart:.*yes")" -ne 0 ] || sudo virsh net-autostart default
            line_a='unix_sock_group = "libvirt"'
            line_b='unix_sock_rw_perms = "0770"'
            sudo sed -i "/$line_a/s/^#//" /etc/libvirt/libvirtd.conf
            sudo sed -i "/$line_b/s/^#//" /etc/libvirt/libvirtd.conf
        }
        ;;

    *) echo "wrong usage" ;;
    esac
done
