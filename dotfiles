#!/bin/bash

RED='\033[1;31m'
GRN='\033[1;32m'
CLR='\033[0m'
remote="https://gitlab.com/printfdebugging/dotfiles/-/raw/main"

function fcp() {
    [ -f "./$1" ] && cp ./"$1" "$2/$1" && echo -e "$GRN==>$CLR copied $2/$1" && return
    curl -s -L "$remote/$1" -o "$2/$1" && echo -e "$GRN==>$CLR fetched $2/$1"
}

function sfcp() {
    [ -f "./$1" ] && sudo cp ./"$1" "$2/$1" && echo -e "$GRN==>$CLR copied $2/$1" && return
    sudo curl -s -L "$remote/$1" -o "$2/$1" && echo -e "$GRN==>$CLR fetched $2/$1"
}

[ "$#" -eq 0 ] && set -- packages files services groups drives mirrorlist browser suckless passwords git pam-gnupg shell qemu # pacman

for arg in "$@"; do
    case "$arg" in
    "files")
        {
            mkdir -p "$HOME/.local/share/wallpapers/"
            mkdir -p "$HOME/.local/share/applications"
            mkdir -p "$HOME/.ssh"
            mkdir -p "$HOME/.gnupg"
            mkdir -p "$HOME/.config"
            mkdir -p "$HOME/.config/nvim"
            mkdir -p "$HOME/.config/tmux"
            mkdir -p "$HOME/.config/mpv"
            mkdir -p "$HOME/.config/gdb"
            mkdir -p "$HOME/.config/gtk-3.0"
            mkdir -p "$HOME/.config/qt6ct"
            mkdir -p "$HOME/.config/flameshot"
            mkdir -p "$HOME/.config/dunst"
            mkdir -p "$HOME/.config/ccache"
            mkdir -p "$HOME/.config/Code - OSS/User/"

            # copy files
            fcp .zshrc "$HOME"
            fcp .zprofile "$HOME"
            fcp .xinitrc "$HOME"
            fcp .gitconfig "$HOME"
            fcp .gpgkey.asc "$HOME"
            fcp .pgpkey.asc "$HOME"
            fcp .pam-gnupg "$HOME"
            fcp id_ed25519 "$HOME/.ssh"
            fcp id_ed25519.pub "$HOME/.ssh"
            fcp printfdebugging "$HOME/.ssh"
            fcp printfdebugging.pub "$HOME/.ssh"
            fcp cool "$HOME/.ssh"
            fcp cool.pub "$HOME/.ssh"
            fcp config "$HOME/.ssh"
            fcp gpg-agent.conf "$HOME/.gnupg"
            fcp gpg.conf "$HOME/.gnupg"
            fcp glade.conf "$HOME/.config"
            fcp okularrc "$HOME/.config"
            fcp kwalletrc "$HOME/.config"
            fcp mimeapps.list "$HOME/.config"
            fcp init.lua "$HOME/.config/nvim"
            fcp tmux.conf "$HOME/.config/tmux"
            fcp input.conf "$HOME/.config/mpv"
            fcp mpv.conf "$HOME/.config/mpv"
            fcp gdbinit "$HOME/.config/gdb"
            fcp settings.ini "$HOME/.config/gtk-3.0"
            fcp qt6ct.conf "$HOME/.config/qt6ct"
            fcp flameshot.ini "$HOME/.config/flameshot"
            fcp dunstrc "$HOME/.config/dunst"
            fcp ccache.conf "$HOME/.config/ccache"
            fcp map.jpg "$HOME/.local/share/wallpapers"
            fcp extensions.json "$HOME/.config/Code - OSS/User"
            fcp keybindings.json "$HOME/.config/Code - OSS/User"
            fcp settings.json "$HOME/.config/Code - OSS/User"

            # copy files with root previliges
            sfcp twemoji.ttf /usr/share/fonts
            sfcp 75-twemoji.conf /etc/fonts/conf.d
            sfcp nginx.conf /etc/nginx
            sfcp 00-keyboard.conf /etc/X11/xorg.conf.d
            sfcp 30-touchpad.conf /etc/X11/xorg.conf.d
            sfcp user-dirs.dirs "$HOME/.config"

            # decrypt secrets after copy
            while ! ansible-vault decrypt \
                "$HOME/.gitconfig" \
                "$HOME/.gpgkey.asc" \
                "$HOME/.pgpkey.asc" \
                "$HOME/.pam-gnupg" \
                "$HOME/.gnupg/gpg-agent.conf" \
                "$HOME/.gnupg/gpg.conf" \
                "$HOME/.ssh/id_ed25519" \
                "$HOME/.ssh/id_ed25519.pub" \
                "$HOME/.ssh/printfdebugging" \
                "$HOME/.ssh/printfdebugging.pub" \
                "$HOME/.ssh/cool" \
                "$HOME/.ssh/cool.pub" \
                "$HOME/.ssh/config"; do
                echo -e "$RED==>$CLR wrong password, please try again!!"
            done

            # import encryption gpg key
            while ! gpg --import "$HOME/.pgpkey.asc"; do
                echo -e "$RED==>$CLR wrong password, please try again!!"
            done

            # setup stricter file permissions in $HOME/.ssh
            chown -R "$(whoami)" "$HOME/.ssh"
            find "$HOME/.ssh" -type f -exec chmod 600 {} \;
            find "$HOME/.ssh" -type d -exec chmod 700 {} \;

            # setup stricter file permissions in $HOME/.gnupg
            chown -R "$(whoami)" "$HOME/.gnupg"
            find "$HOME/.gnupg" -type f -exec chmod 600 {} \;
            find "$HOME/.gnupg" -type d -exec chmod 700 {} \;

            # get ssh keys for github and gitlab
            ssh-keyscan -t rsa "github.com" >>"$HOME/.ssh/known_hosts"
            ssh-keyscan -t rsa "gitlab.com" >>"$HOME/.ssh/known_hosts"
        }
        ;;

    "packages")
        {
            sudo pacman -S --noconfirm \
                'abseil-cpp' \
                'ansible' \
