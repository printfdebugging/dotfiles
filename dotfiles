    drives \
    packages files services groups \
    git pam-gnupg shell qemu # pacman mirrorlist

for arg in "$@"; do
    case "$arg" in
    "files")
        {
            mkdir -p \
                "$HOME/.local/share/wallpapers/" \
                "$HOME/.local/share/applications" \
                "$HOME/.ssh" \
                "$HOME/.gnupg" \
                "$HOME/.config" \
                "$HOME/.config/nvim" \
                "$HOME/.config/nvim/after/queries/c" \
                "$HOME/.config/nvim/after/queries/cpp" \
                "$HOME/.config/nvim/after/queries/glsl" \
                "$HOME/.config/xfce4/xfconf/xfce-perchannel-xml" \
                "$HOME/.config/tmux" \
                "$HOME/.config/mpv" \
                "$HOME/.config/gdb" \
                "$HOME/.config/gtk-3.0" \
                "$HOME/.config/qt6ct" \
                "$HOME/.config/flameshot" \
                "$HOME/.config/dunst" \
                "$HOME/.config/ccache" \
                "$HOME/.config/Code - OSS/User/"

            # copy files
            cp .zshrc "$HOME"
            cp .zshenv "$HOME"
            cp .zprofile "$HOME"
            cp .xinitrc "$HOME"
            cp .gitconfig "$HOME"
            cp .gmail.asc "$HOME"
            cp .proton.asc "$HOME"
            cp .pam-gnupg "$HOME"
            cp printfdebugging "$HOME/.ssh"
            cp printfdebugging.pub "$HOME/.ssh"
            cp cool "$HOME/.ssh"
            cp cool.pub "$HOME/.ssh"
            cp config "$HOME/.ssh"
            cp gpg-agent.conf "$HOME/.gnupg"
            cp thunar.xml "$HOME/.config/xfce4/xfconf/xfce-perchannel-xml"
            cp thunar-shares-plugin.xml "$HOME/.config/xfce4/xfconf/xfce-perchannel-xml"
            cp gpg.conf "$HOME/.gnupg"
            cp glade.conf "$HOME/.config"
            cp okularrc "$HOME/.config"
            cp kwalletrc "$HOME/.config"
            cp mimeapps.list "$HOME/.config"
            cp init.lua "$HOME/.config/nvim"
            cp injections.scm "$HOME/.config/nvim/after/queries/c"
            cp injections.scm "$HOME/.config/nvim/after/queries/cpp"
            cp injections.scm "$HOME/.config/nvim/after/queries/glsl"
            cp tmux.conf "$HOME/.config/tmux"
            cp input.conf "$HOME/.config/mpv"
            cp mpv.conf "$HOME/.config/mpv"
            cp gdbinit "$HOME/.config/gdb"
            cp settings.ini "$HOME/.config/gtk-3.0"
            cp qt6ct.conf "$HOME/.config/qt6ct"
            cp flameshot.ini "$HOME/.config/flameshot"
            cp dunstrc "$HOME/.config/dunst"
            cp ccache.conf "$HOME/.config/ccache"
            cp map.png "$HOME/.local/share/wallpapers"
            cp second.jpg "$HOME/.local/share/wallpapers"
            cp extensions.json "$HOME/.config/Code - OSS/User"
            cp keybindings.json "$HOME/.config/Code - OSS/User"
            cp settings.json "$HOME/.config/Code - OSS/User"

            # copy files with root previliges
            sudo cp twemoji.ttf /usr/share/fonts
            sudo cp 75-twemoji.conf /etc/fonts/conf.d
            sudo cp nginx.conf /etc/nginx
            sudo cp 00-keyboard.conf /etc/X11/xorg.conf.d
            sudo cp 30-touchpad.conf /etc/X11/xorg.conf.d
            sudo cp user-dirs.dirs "$HOME/.config"

            # decrypt secrets after copy
            while ! ansible-vault decrypt \
                "$HOME/.gitconfig" \
                "$HOME/.gmail.asc" \
                "$HOME/.proton.asc" \
                "$HOME/.pam-gnupg" \
                "$HOME/.gnupg/gpg-agent.conf" \
                "$HOME/.gnupg/gpg.conf" \
                "$HOME/.ssh/printfdebugging" \
                "$HOME/.ssh/printfdebugging.pub" \
                "$HOME/.ssh/cool" \
                "$HOME/.ssh/cool.pub" \
                "$HOME/.ssh/config"; do
                echo -e "$RED==>$CLR wrong password, please try again!!"
            done

            # import encryption gpg key
            while ! gpg --import "$HOME/.gmail.asc"; do
                echo -e "$RED==>$CLR wrong password, please try again!!"
            done

            # setup stricter file permissions in $HOME/.ssh
            chown -R "$(whoami)" "$HOME/.ssh"
            find "$HOME/.ssh" -type f -exec chmod 600 {} \;
            find "$HOME/.ssh" -type d -exec chmod 700 {} \;

            # setup stricter file permissions in $HOME/.gnupg
            chown -R "$(whoami)" "$HOME/.gnupg"
            find "$HOME/.gnupg" -type f -exec chmod 600 {} \;
            find "$HOME/.gnupg" -type d -exec chmod 700 {} \;

            # get ssh keys for github and gitlab
            {
                ssh-keyscan -t rsa "github.com"
                ssh-keyscan -t rsa "gitlab.com"
                ssh-keyscan -t rsa "codeberg.org"
            } >>"$HOME/.ssh/known_hosts"
        }
        ;;

    "packages")
